<Window x:Class="SecurityBaselineGUI.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SecurityBaselineGUI.App.ViewModels"
        xmlns:conv="clr-namespace:SecurityBaselineGUI.App.Converters"
        x:Name="RootWindow"
        Title="Security Baseline (LAPS / LSA Protection / ASR)"
        Height="720" Width="980"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- プロファイルバー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="プロファイル:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Width="220" ItemsSource="{Binding ProfileNames}" SelectedItem="{Binding ProfileName, Mode=OneWayToSource}"
                      SelectionChanged="ProfileComboBox_SelectionChanged"/>
            <TextBox Width="160" Margin="12,0,0,0" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="保存する名前を入力"/>
            <Button Content="保存" Margin="6,0,0,0" Command="{Binding SaveProfileCommand}"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="基本">
                <StackPanel Margin="12">
                    <TextBlock Text="GPO名(ベース)" FontWeight="Bold"/>
                    <TextBox Text="{Binding GpoBaseName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                    <TextBlock Text="現在作業中のOU" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                               Text="対象OUの選択は左側の「対象OUの選択」ウィンドウで行います。ここには現在の選択状況を表示します。"/>
                    <ItemsControl ItemsSource="{Binding SelectedOus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding DistinguishedName}" FontSize="11" Foreground="Gray"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </TabItem>

            <TabItem Header="LAPS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <GroupBox Header="スキーマ拡張" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="LAPSスキーマを拡張する" IsChecked="{Binding PerformSchemaExtension}"
                                          IsEnabled="{Binding IsLapsSchemaExtended, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Content="再確認" Margin="12,0,0,0" Padding="6,0" Command="{Binding RefreshLapsSchemaStatusCommand}"/>
                            </StackPanel>
                            <TextBlock Margin="0,4,0,0" Foreground="Gray" FontSize="11" Text="{Binding LapsSchemaStatusMessage}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="パスワード基本設定" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Text="パスワード長 (8-64)"/>
                            <TextBox Text="{Binding LapsPasswordLength, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                            <TextBlock Text="ローテーション間隔(日) (1-365)"/>
                            <TextBox Text="{Binding LapsPasswordAgeDays, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                            <TextBlock Text="パスワード複雑さ (PasswordComplexity)"/>
                            <ComboBox ItemsSource="{Binding PasswordComplexityOptions}" SelectedItem="{Binding LapsPasswordComplexity}"
                                      Width="360" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                            <CheckBox Content="パスワード有効期限の強制を有効にする (PasswordExpirationProtectionEnabled)"
                                      IsChecked="{Binding LapsPasswordExpirationProtectionEnabled}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="認証後アクション" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Text="実行するアクション (PostAuthenticationActions)"/>
                            <ComboBox ItemsSource="{Binding PostAuthenticationActionOptions}" SelectedItem="{Binding LapsPostAuthenticationActions}"
                                      Width="360" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                            <TextBlock Text="猶予時間(時間) (PostAuthenticationResetDelay, 0-24)"/>
                            <TextBox Text="{Binding LapsPostAuthenticationResetDelay, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="管理対象アカウント" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Text="管理対象ローカル管理者アカウント名(空欄=組み込みAdministrator)"/>
                            <TextBox Text="{Binding LapsAdministratorAccountName, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Active Directory暗号化" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <CheckBox Content="ADに保存するパスワードを暗号化する (ADPasswordEncryptionEnabled)"
                                      IsChecked="{Binding LapsADPasswordEncryptionEnabled}" Margin="0,0,0,12"/>
                            <TextBlock Text="復号を許可するユーザー/グループ(空欄=Domain Adminsのみ)"/>
                            <TextBox Text="{Binding LapsADPasswordEncryptionPrincipal, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                            <TextBlock Text="暗号化パスワード履歴の世代数 (0-12)"/>
                            <TextBox Text="{Binding LapsADEncryptedPasswordHistorySize, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                            <CheckBox Content="ドメインコントローラーのDSRMパスワードもバックアップする (ADBackupDSRMPassword)"
                                      IsChecked="{Binding LapsADBackupDSRMPassword}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="LSA Protection">
                <StackPanel Margin="12">
                    <CheckBox Content="UEFIロック付きで有効化 (LsaProtectionUefiLock)" IsChecked="{Binding LsaProtectionUefiLock}"/>
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="DarkOrange"
                               Text="注意: UEFIロックを有効にすると、無効化にはセキュアブート経由の操作が必要になり復旧が困難です。"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="ASR">
                <DockPanel Margin="12">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="一括モード:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="120" ItemsSource="{Binding AsrModes}" SelectedItem="{Binding BulkAsrMode}"/>
                        <Button Content="全ルールに適用" Margin="8,0,0,0" Command="{Binding ApplyBulkAsrModeCommand}"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding AsrRules}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="有効" Binding="{Binding IsEnabled}" Width="50"/>
                            <DataGridTextColumn Header="ルール名" Binding="{Binding Name}" Width="3*" IsReadOnly="True"/>
                            <DataGridComboBoxColumn Header="モード" SelectedItemBinding="{Binding Mode}"
                                                     ItemsSource="{Binding DataContext.AsrModes, ElementName=RootWindow}"
                                                     Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="除外設定">
                <DockPanel Margin="12">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Width="400" Text="{Binding NewExclusionPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="追加" Margin="8,0,0,0" Command="{Binding AddExclusionPathCommand}"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="Gray"
                               Text="ASR除外は全ルール共通です(Defenderの仕様上ルール単位の個別除外は不可)。ワイルドカードや環境変数(%ProgramFiles%等)を使用できます。"/>
                    <ListBox ItemsSource="{Binding ExclusionPaths}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" Width="500" VerticalAlignment="Center"/>
                                    <Button Content="削除"
                                            Command="{Binding DataContext.RemoveExclusionPathCommand, ElementName=RootWindow}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <TabItem Header="スクリプト管理">
                <StackPanel Margin="12">
                    <TextBlock Text="現在のスクリプト" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ScriptPath}" TextWrapping="Wrap" Margin="0,0,0,12" FontFamily="Consolas" FontSize="11"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:" FontWeight="Bold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ScriptVersion}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="SHA256:" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ScriptSha256}" FontFamily="Consolas" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="更新日時:" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ScriptLastModified}" Margin="0,4,0,0"/>
                    </Grid>

                    <Button Content="スクリプトを更新..." HorizontalAlignment="Left" Padding="8,4" Click="UpdateScriptButton_Click"/>
                    <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="Gray"
                               Text="新しいps1を選択すると、構文チェック→パラメータ差分表示→確認のうえで、現行スクリプトをArchiveフォルダにバックアップしてから差し替えます。"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="バックアップ">
                <StackPanel Margin="12">
                    <CheckBox Content="定期バックアップを有効にする" IsChecked="{Binding BackupEnabled}" Margin="0,0,0,12"/>

                    <TextBlock Text="バックアップ間隔(時間)"/>
                    <TextBox x:Name="BackupIntervalHoursTextBox" AutomationProperties.AutomationId="BackupIntervalHoursTextBox"
                             Text="{Binding BackupIntervalHours, UpdateSourceTrigger=PropertyChanged}"
                             Width="100" HorizontalAlignment="Left" Margin="0,4,0,12"/>

                    <TextBlock Text="バックアップ先フォルダー"/>
                    <DockPanel Margin="0,4,0,12">
                        <Button Content="参照..." DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseBackupDestinationButton_Click"/>
                        <TextBox x:Name="BackupDestinationTextBox" AutomationProperties.AutomationId="BackupDestinationTextBox"
                                 Text="{Binding BackupDestination, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <Button Content="設定を保存" HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,16"
                            Command="{Binding SaveBackupSettingsCommand}"/>

                    <Separator Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="今すぐバックアップ" Padding="8,4" Command="{Binding BackupNowCommand}"/>
                        <Button Content="バックアップから復元..." Padding="8,4" Margin="8,0,0,0" Click="RestoreBackupButton_Click"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LastBackupText}"/>

                    <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Foreground="Gray"
                               Text="バックアップはDBファイルとDPAPI保護済み鍵ファイルを常にペアでコピーします(片方だけでは復号できません)。復元後は変更を反映するためアプリの再起動が必要です。ハードウェア故障時は、同一ドメインアカウントで別マシンにこのペアをコピーして復元してください(ドメイン参加環境が前提。7.2章参照)。"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="履歴">
                <DockPanel Margin="12">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="更新" Command="{Binding RefreshHistoryCommand}"/>
                        <Button Content="CSVエクスポート" Margin="8,0,0,0" Click="ExportCsvButton_Click"/>
                        <Button Content="列のカスタマイズ" Margin="8,0,0,0" Click="CustomizeCsvColumnsButton_Click"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日時" Binding="{Binding Timestamp}" Width="160"/>
                            <DataGridTextColumn Header="ユーザー" Binding="{Binding UserName}" Width="100"/>
                            <DataGridTextColumn Header="TargetOU" Binding="{Binding TargetOU}" Width="2*"/>
                            <DataGridTextColumn Header="GPOName" Binding="{Binding GPOName}" Width="1*"/>
                            <DataGridTextColumn Header="WhatIf" Binding="{Binding WasWhatIf}" Width="60"/>
                            <DataGridTextColumn Header="結果" Binding="{Binding Succeeded}" Width="60"/>
                            <DataGridTextColumn Header="所要時間(ms)" Binding="{Binding DurationMs}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <GroupBox Grid.Row="2" Header="ログ" Margin="0,8,0,8">
            <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"/>
        </GroupBox>

        <DockPanel Grid.Row="3">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="プレビュー (WhatIf)" Padding="12,4" Margin="0,0,8,0"
                        Command="{Binding PreviewCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="実行" Padding="12,4" FontWeight="Bold"
                        Command="{Binding RunCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
