<Window x:Class="SecurityBaselineGUI.App.Views.OuSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SecurityBaselineGUI.App.ViewModels"
        xmlns:conv="clr-namespace:SecurityBaselineGUI.App.Converters"
        x:Name="RootWindow"
        Title="対象OUの選択(常時表示)"
        Height="720" Width="360"
        ShowInTaskbar="True"
        d:DataContext="{d:DesignInstance vm:OuSelectorViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.Resources>
        <conv:PlaceholderOpacityConverter x:Key="PlaceholderOpacityConverter"/>
        <conv:EmptyStringToCollapsedConverter x:Key="EmptyStringToCollapsedConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="GPO名(ベース)" FontWeight="Bold"/>
            <TextBox Text="{Binding GpoBaseName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="Gray" FontSize="11"
                       Text="実行時は選択したOUごとに「ベース名-OU名」のGPOが作成されます。"/>
        </StackPanel>

        <TreeView Grid.Row="1" ItemsSource="{Binding RootNodes}">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Visibility="{Binding IsSelectable, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Name}" Opacity="{Binding IsPlaceholder, Converter={StaticResource PlaceholderOpacityConverter}}" VerticalAlignment="Center"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,8,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource EmptyStringToCollapsedConverter}}"/>

        <DockPanel Grid.Row="3" Margin="0,12,0,4">
            <TextBlock Text="現在作業中のOU" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <Button Content="選択をクリア" DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="6,2"
                    Command="{Binding ClearSelectionCommand}"/>
        </DockPanel>

        <ListBox Grid.Row="4" ItemsSource="{Binding SelectedOus}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DistinguishedName}" FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="削除" Padding="6,2" VerticalAlignment="Top"
                                Command="{Binding DataContext.RemoveSelectedCommand, ElementName=RootWindow}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
